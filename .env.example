# ─────────────────────────────────────────────
# x2xhs 环境变量模板
# 复制为 .env 并填入真实值，.env 不会被提交到 Git
# ─────────────────────────────────────────────

# ── AI 翻译（必填）─────────────────────────────
# OpenRouter API Key（用于 Claude 翻译）
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 翻译模型（可选，默认 deepseek/deepseek-chat）
# 推荐：anthropic/claude-sonnet-4-6 效果最好，deepseek/deepseek-chat 最经济
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# ── RSSHub（必填）──────────────────────────────
# 本地或远程 RSSHub 实例，用于账号推文抓取
# 本地部署：docker run -p 1200:1200 diygod/rsshub
RSSHUB_BASE_URL=http://localhost:1200

# ── 抓取配置（可选）────────────────────────────
# 监控的 Twitter 账号（逗号分隔，不含 @）
SCRAPER_ACCOUNTS=claudeai,AnthropicAI,sama,elonmusk,karpathy,realDonaldTrump

# 关键词搜索（逗号分隔），需配合 TWSCRAPE_* 使用
SCRAPER_KEYWORDS=AI agents,LLM,Claude,GPT

# 每次抓取最多条数（默认 20）
SCRAPER_MAX_TWEETS=20

# 关键词搜索互动量门槛（默认：100 赞 / 20 转发）
TWITTER_MIN_FAVES=100
TWITTER_MIN_RETWEETS=20

# ── Twitter Cookie（关键词搜索用）─────────────
# 用于 Playwright 拦截 SearchTimeline API，建议使用小号
# 获取方式：登录 x.com → 浏览器 DevTools → Application → Cookies
TWSCRAPE_AUTH_TOKEN=your_auth_token_cookie_here
TWSCRAPE_CT0=your_ct0_cookie_here

# ── Twitter Cookie（推文截图用）───────────────
# 截图功能单独使用一个 auth_token（可与上面相同）
TWITTER_AUTH_TOKEN=your_auth_token_for_screenshot_here

# ── Telegram Bot（必填，用于推送通知）─────────
# BotFather 创建 bot 后获得 Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 目标 chat ID（个人或频道），可用 @userinfobot 获取
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── 定时任务间隔（可选）────────────────────────
# bot 自动抓取+发送的间隔（分钟，默认 60）
POLL_INTERVAL_MINUTES=60

# ── 字体（可选，VPS 部署时使用）──────────────
# Ubuntu 安装 CJK 字体：sudo apt install fonts-noto-cjk
# FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc
